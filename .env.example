# 기상청 API 허브 인증키 (authKey)
# https://apihub.kma.go.kr/ 에서 발급받아 입력하세요.
# 단기예보, 중기예보, 기상특보, 영향예보, 예보·특보 구역정보 모두 동일 키 사용.
KOREA_WEATHER_API_KEY=

# HTTP 서버 listen 주소/포트 (기본: 127.0.0.1:8081)
HOST=127.0.0.1
PORT=8081

# HTTP 모드 인증 키 (x-api-key 헤더로 전달).
# HTTP 모드 실행 시 필수이며, 미설정 시 서버가 시작되지 않습니다.
MCP_API_KEY=
